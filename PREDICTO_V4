    "# ═══════════════════════════════════════════════════════════════\n",
    "# CÉLULA 5 — submission v4\n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "import src.submit as _submit\n",
    "from src.data import parse_submission_ids\n",
    "from src.submit import generate_submission\n",
    "\n",
    "sub_all = parse_submission_ids(sub_stage2)\n",
    "\n",
    "def _gen_matchups_patch(season, m_seeds, w_seeds):\n",
    "    df = sub_all[sub_all[\"Season\"] == season].copy()\n",
    "    df[\"LowHome\"]      = 0\n",
    "    df[\"HighHome\"]     = 0\n",
    "    df[\"ActualLowWin\"] = 0\n",
    "    return df\n",
    "\n",
    "_submit._generate_all_matchups = _gen_matchups_patch\n",
    "\n",
    "sub = generate_submission(CONFIG, output_path=\"/kaggle/working/submission.csv\")\n",
    "\n",
    "# Garantir exatamente as linhas do Stage2\n",
    "sub_gerado = pd.read_csv(\"/kaggle/working/submission.csv\")\n",
    "sub_final  = sub_stage2[[\"ID\"]].merge(sub_gerado, on=\"ID\", how=\"left\")\n",
    "sub_final[\"Pred\"] = sub_final[\"Pred\"].fillna(sub_gerado[\"Pred\"].mean())\n",
    "\n",
    "print(\"\\n── SUBMISSION FINAL v4 ──\")\n",
    "print(\"Rows :\", len(sub_final))\n",
    "print(\"NaN  :\", sub_final[\"Pred\"].isna().sum())\n",
    "print(\"Min  :\", round(sub_final[\"Pred\"].min(), 4))\n",
    "print(\"Max  :\", round(sub_final[\"Pred\"].max(), 4))\n",
    "print(\"Mean :\", round(sub_final[\"Pred\"].mean(), 4))\n",
    "\n",
    "sub_final.to_csv(\"/kaggle/working/submission.csv\", index=False)\n",
    "sub_final.head(10)"
   ]
