    "# ═══════════════════════════════════════════════════════════════\n",
    "# CÉLULA 3 — config v5\n",
    "# ═══════════════════════════════════════════════════════════════\n",
    "import pandas as pd\n",
    "from src.config import CONFIG\n",
    "\n",
    "CONFIG[\"data_dir\"] = DATA_DIR\n",
    "\n",
    "# ── Elo ────────────────────────────────────────────────────────\n",
    "CONFIG[\"elo_k_factor\"]       = 18.0\n",
    "CONFIG[\"elo_carry_factor\"]   = 0.82\n",
    "CONFIG[\"elo_margin_cap\"]     = 15.0\n",
    "CONFIG[\"elo_use_margin\"]     = True\n",
    "CONFIG[\"elo_initial_rating\"] = 1500.0   # CRÍTICO — era 100\n",
    "\n",
    "# ── Poisson ────────────────────────────────────────────────────\n",
    "CONFIG[\"max_points_poisson\"]   = 155\n",
    "CONFIG[\"alpha_ci\"]              = 0.12\n",
    "CONFIG[\"poisson_shrinkage\"]     = 0.20\n",
    "CONFIG[\"poisson_blend_weights\"] = {\n",
    "    \"recent3\": 0.50,   # peso alto na forma recente\n",
    "    \"recent5\": 0.30,\n",
    "    \"season\":  0.20,\n",
    "}\n",
    "\n",
    "# ── Clipping ───────────────────────────────────────────────────\n",
    "CONFIG[\"pred_clip_min\"] = 0.05\n",
    "CONFIG[\"pred_clip_max\"] = 0.95\n",
    "CONFIG[\"temperature_candidates\"] = [0.90, 1.00, 1.05, 1.10, 1.12, 1.15, 1.20, 1.25]\n",
    "\n",
    "# ── XGBoost ────────────────────────────────────────────────────\n",
    "CONFIG[\"xgb_params\"].update({\n",
    "    \"n_estimators\":     800,\n",
    "    \"learning_rate\":    0.03,\n",
    "    \"max_depth\":        3,\n",
    "    \"subsample\":        0.80,\n",
    "    \"colsample_bytree\": 0.70,\n",
    "    \"min_child_weight\": 6,\n",
    "    \"reg_lambda\":       6.0,\n",
    "    \"reg_alpha\":        0.5,\n",
    "    \"gamma\":            0.2,\n",
    "})\n",
    "\n",
    "# ── Blend — Poisson + XGBoost dominantes, manual mínimo ───────\n",
    "CONFIG[\"blend_weights\"] = {\n",
    "    \"xgb\":     0.42,\n",
    "    \"poisson\": 0.32,\n",
    "    \"elo\":     0.20,\n",
    "    \"manual\":  0.06,\n",
    "    \"seed\":    0.00,\n",
    "}\n",
    "\n",
    "# ── Manual — peso mínimo, só forma recente e Poisson ──────────\n",
    "CONFIG[\"manual_feature_weights\"] = {\n",
    "    \"seed_diff\":                 0.10,\n",
    "    \"elo_diff\":                  0.20,\n",
    "    \"season_margin_diff\":        0.15,\n",
    "    \"season_win_pct_diff\":       0.10,\n",
    "    \"recent3_margin_diff\":       0.40,   # forma recente — sinal mais forte\n",
    "    \"recent5_margin_diff\":       0.30,\n",
    "    \"matchup_diff\":              0.20,\n",
    "    \"poisson_win_prob_centered\": 0.50,   # Poisson — sinal mais forte\n",
    "    \"quality_diff\":              0.15,\n",
    "    \"sos_diff\":                  0.10,\n",
    "    \"rank_diff_signed\":          0.10,\n",
    "    \"consistency_edge\":          0.05,\n",
    "}\n",
    "\n",
    "# ── Features XGBoost — todas as disponíveis ───────────────────\n",
    "CONFIG[\"feature_cols\"] = [\n",
    "    \"seed_diff\",\n",
    "    \"elo_diff\",\n",
    "    \"season_points_for_diff\",\n",
    "    \"season_points_against_diff\",\n",
    "    \"season_margin_diff\",\n",
    "    \"season_win_pct_diff\",\n",
    "    \"recent3_points_for_diff\",\n",
    "    \"recent3_points_against_diff\",\n",
    "    \"recent3_margin_diff\",\n",
    "    \"recent5_points_for_diff\",\n",
    "    \"recent5_points_against_diff\",\n",
    "    \"recent5_margin_diff\",\n",
    "    \"matchup_diff\",\n",
    "    \"offense_vs_defense_low\",\n",
    "    \"offense_vs_defense_high\",\n",
    "    \"sos_diff\",\n",
    "    \"quality_diff\",\n",
    "    \"rank_diff_signed\",\n",
    "    \"poisson_lambda_low\",\n",
    "    \"poisson_lambda_high\",\n",
    "    \"poisson_expected_margin\",\n",
    "    \"poisson_win_prob\",\n",
    "    \"poisson_win_prob_centered\",\n",
    "    \"consistency_edge\",\n",
    "    \"season_trajectory_diff\",\n",
    "    \"quality_win_pct_diff\",\n",
    "    \"blowout_pct_diff\",\n",
    "    \"close_game_win_pct_diff\",\n",
    "]\n",
    "\n",
    "# ── Target season ─────────────────────────────────────────────\n",
    "sub_stage2 = pd.read_csv(f\"{DATA_DIR}/SampleSubmissionStage2.csv\")\n",
    "CONFIG[\"target_season\"] = int(\n",
    "    sub_stage2[\"ID\"].str.split(\"_\").str[0].mode()[0]\n",
    ")\n",
    "print(\"target_season :\", CONFIG[\"target_season\"])\n",
    "print(\"Stage2 rows   :\", len(sub_stage2))\n",
    "print(\"blend_weights :\", CONFIG[\"blend_weights\"])\n",
    "print(\"elo_initial   :\", CONFIG[\"elo_initial_rating\"])"
   ]
  },
